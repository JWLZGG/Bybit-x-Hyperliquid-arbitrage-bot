ENVIRONMENT=testnet
BYBIT_REST_URL=https://api-testnet.bybit.com
HYPERLIQUID_REST_URL=https://api.hyperliquid-testnet.xyz
BYBIT_API_KEY=your_bybit_key_here
BYBIT_API_SECRET=your_bybit_secret_here
BYBIT_ACCOUNT_TYPE=UNIFIED
BYBIT_SETTLE_COIN=USDT
BYBIT_RECV_WINDOW_MS=5000
BYBIT_EQUITY_OVERRIDE_USD=
BYBIT_AVAILABLE_BALANCE_OVERRIDE_USD=
BYBIT_MARGIN_USED_OVERRIDE_USD=
HYPERLIQUID_PRIVATE_KEY=your_hyperliquid_private_key_here
HYPERLIQUID_VAULT_ADDRESS=
HYPERLIQUID_ACCOUNT_ADDRESS=
HYPERLIQUID_EQUITY_OVERRIDE_USD=
HYPERLIQUID_AVAILABLE_BALANCE_OVERRIDE_USD=
HYPERLIQUID_MARGIN_USED_OVERRIDE_USD=
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DATABASE_PATH=./arbitrage_bot.db
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/arbitrage_bot.log
POLL_INTERVAL_SECONDS=5
ALLOW_DEGRADED_MODE=false
BYBIT_MAKER_FEE_BP=2.0
HYPERLIQUID_MAKER_FEE_BP=1.5
SLIPPAGE_BUFFER_BP=4.0
SAFETY_MARGIN_BP=5.0
MIN_NET_EXPECTED_RETURN_BP=0.1
MAX_POSITION_NOTIONAL_USD=10000
MIN_GROSS_8H_FUNDING_DIFF_BP=16.0
MAX_FUNDING_PREDICTION_HORIZON_HOURS=8
MIN_GROSS_ENTRY_SPREAD_BP=16.0
MAX_HOLD_TIME_MINUTES=5
EXPECTED_CONVERGENCE_PCT=85.0
LIQUIDITY_DEPTH_FRACTION_LIMIT=0.005
MAX_MARGIN_UTILIZATION=0.30
LATENCY_GUARD_MS=500
MIN_MARGIN_RATIO_PCT=150
VOLATILITY_SPIKE_PCT_1M=2.0
RECONCILIATION_INTERVAL_SECONDS=30
EXECUTION_ORDER_TIMEOUT_SECONDS=6
EXECUTION_STATUS_POLL_INTERVAL_SECONDS=1.0
PAUSE_ON_ZERO_EFFECTIVE_CAPITAL=true
NEAR_MISS_THRESHOLD_RATIO=0.80
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_REFRESH_SECONDS=5
ALERT_WEBHOOK_URL=
RUN_ONCE=false
